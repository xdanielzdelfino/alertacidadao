## Copy this file to `keystore.properties` and fill values. Do NOT commit `keystore.properties`.
# Path to keystore file relative to project root
storeFile=alertacidadao.keystore
# Keystore password
storePassword=CHANGEME
# Key alias inside the keystore
keyAlias=alertacidadao
# Key password (often same as storePassword)
keyPassword=CHANGEME
