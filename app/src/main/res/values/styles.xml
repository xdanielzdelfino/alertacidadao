        <item name="postSplashScreenTheme">@style/Theme.AlertaCidadao</item>
        <item name="android:windowActionBar">false</item>
        <item name="windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Base.Theme.AlertaCidadao" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowActionBar">false</item>
        <item name="windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="windowNoTitle">true</item>
    </style>
    <style name="Theme.AlertaCidadao" parent="Base.Theme.AlertaCidadao" />
