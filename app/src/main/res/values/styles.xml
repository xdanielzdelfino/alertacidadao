<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="RoundedCornerLogo">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">28dp</item>
    </style>

    <style name="RoundedCornerLogoSmall">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="RoundedCornerInput">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">30dp</item>
    </style>

    <style name="RoundedCornerInputSmall">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <style name="Theme.AlertaCidadao.Launcher" parent="Theme.SplashScreen">
