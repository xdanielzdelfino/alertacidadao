<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/auth_background"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.cardview.widget.CardView
            android:id="@+id/card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="28dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="40dp"
            app:cardPreventCornerOverlap="false"
            app:cardElevation="12dp"
            app:cardUseCompatPadding="false"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="112dp"
                    android:background="@drawable/container_cadastro"
                    android:clipToPadding="true">

                    <ImageButton
                        android:id="@+id/buttonBack"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_alignParentStart="true"
                        android:layout_alignParentTop="true"
                        android:layout_marginStart="10dp"
                        android:layout_marginTop="8dp"
                        android:background="@android:color/transparent"
                        android:contentDescription="@string/auth_back"
                        android:src="@drawable/ic_arrow_back"
                        app:tint="@color/text_header_light" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/buttonBack"
                        android:layout_marginTop="2dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/bg_logo_container">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@string/app_name"
                                android:padding="5dp"
                                android:scaleType="centerInside"
                                android:src="@drawable/img_cadastro" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auth_create_title"
                                android:textColor="@color/text_header_light"
                                android:textSize="19sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auth_create_subtitle"
                                android:textColor="#D8E7F8"
                                android:textSize="12sp" />
                        </LinearLayout>

                    </LinearLayout>
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="18dp"
                    android:paddingTop="18dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="22dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:labelFor="@id/inputName"
                        android:text="@string/auth_full_name_label"
                        android:textColor="#404753"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusBottomEnd="28dp"
                        app:boxCornerRadiusBottomStart="28dp"
                        app:boxCornerRadiusTopEnd="28dp"
                        app:boxCornerRadiusTopStart="28dp"
                        app:boxStrokeColor="#E7E7E7"
                        app:hintEnabled="false"
                        app:startIconDrawable="@drawable/ic_profile_user"
                        app:startIconTint="#8C8C8C">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/inputName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/auth_full_name_hint"
                            android:imeOptions="actionNext"
                            android:inputType="textPersonName"
                            android:minHeight="52dp"
                            android:nextFocusDown="@id/inputEmail"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:textColor="#2E2E2E"
                            android:textColorHint="#8A8A8A" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:labelFor="@id/inputEmail"
                        android:text="@string/auth_email_required_label"
                        android:textColor="#404753"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusBottomEnd="28dp"
                        app:boxCornerRadiusBottomStart="28dp"
                        app:boxCornerRadiusTopEnd="28dp"
                        app:boxCornerRadiusTopStart="28dp"
                        app:boxStrokeColor="#E7E7E7"
                        app:hintEnabled="false"
                        app:startIconDrawable="@drawable/ic_email"
                        app:startIconTint="#8C8C8C">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/inputEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/auth_email_hint"
                            android:imeOptions="actionNext"
                            android:inputType="textEmailAddress"
                            android:minHeight="52dp"
                            android:nextFocusDown="@id/inputPhone"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:textColor="#2E2E2E"
                            android:textColorHint="#8A8A8A" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:baselineAligned="false"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="6dp"
                                android:labelFor="@id/inputPhone"
                                android:text="@string/auth_phone_label"
                                android:textColor="#404753"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/layoutPhone"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:boxBackgroundMode="outline"
                                app:boxCornerRadiusBottomEnd="28dp"
                                app:boxCornerRadiusBottomStart="28dp"
                                app:boxCornerRadiusTopEnd="28dp"
                                app:boxCornerRadiusTopStart="28dp"
                                app:boxStrokeColor="#E7E7E7"
                                app:hintEnabled="false"
                                app:startIconDrawable="@drawable/ic_phone"
                                app:startIconTint="#8C8C8C">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/inputPhone"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="@string/auth_phone_hint"
                                    android:imeOptions="actionNext"
                                    android:inputType="phone"
                                    android:minHeight="52dp"
                                    android:nextFocusDown="@id/inputNeighborhood"
                                    android:paddingStart="12dp"
                                    android:paddingEnd="12dp"
                                    android:textColor="#2E2E2E"
                                    android:textColorHint="#8A8A8A" />
                            </com.google.android.material.textfield.TextInputLayout>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="6dp"
                                android:labelFor="@id/inputNeighborhood"
                                android:text="@string/auth_neighborhood_label"
                                android:textColor="#404753"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/layoutNeighborhood"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:boxBackgroundMode="outline"
                                app:boxCornerRadiusBottomEnd="28dp"
                                app:boxCornerRadiusBottomStart="28dp"
                                app:boxCornerRadiusTopEnd="28dp"
                                app:boxCornerRadiusTopStart="28dp"
                                app:boxStrokeColor="#E7E7E7"
                                app:hintEnabled="false"
                                app:startIconDrawable="@drawable/ic_location"
                                app:startIconTint="#8C8C8C">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/inputNeighborhood"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="@string/auth_neighborhood_hint"
                                    android:imeOptions="actionNext"
                                    android:inputType="text"
                                    android:minHeight="52dp"
                                    android:nextFocusDown="@id/inputPassword"
                                    android:paddingStart="12dp"
                                    android:paddingEnd="12dp"
                                    android:textColor="#2E2E2E"
                                    android:textColorHint="#8A8A8A" />
                            </com.google.android.material.textfield.TextInputLayout>

                        </LinearLayout>

                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:labelFor="@id/inputPassword"
                        android:text="@string/auth_password_required_label"
                        android:textColor="#404753"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusBottomEnd="28dp"
                        app:boxCornerRadiusBottomStart="28dp"
                        app:boxCornerRadiusTopEnd="28dp"
                        app:boxCornerRadiusTopStart="28dp"
                        app:boxStrokeColor="#E7E7E7"
                        app:endIconDrawable="@drawable/figma_create_eye"
                        app:endIconMode="custom"
                        app:endIconTint="#8C8C8C"
                        app:hintEnabled="false"
                        app:startIconDrawable="@android:drawable/ic_lock_lock"
                        app:startIconTint="#8C8C8C">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/inputPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/auth_password_min_hint"
                            android:imeOptions="actionNext"
                            android:inputType="textPassword"
                            android:minHeight="52dp"
                            android:nextFocusDown="@id/inputConfirmPassword"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:textColor="#2E2E2E"
                            android:textColorHint="#8A8A8A" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:labelFor="@id/inputConfirmPassword"
                        android:text="@string/auth_confirm_password_label"
                        android:textColor="#404753"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutConfirmPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusBottomEnd="28dp"
                        app:boxCornerRadiusBottomStart="28dp"
                        app:boxCornerRadiusTopEnd="28dp"
                        app:boxCornerRadiusTopStart="28dp"
                        app:boxStrokeColor="#E7E7E7"
                        app:endIconDrawable="@drawable/figma_create_eye"
                        app:endIconMode="custom"
                        app:endIconTint="#8C8C8C"
                        app:hintEnabled="false"
                        app:startIconDrawable="@android:drawable/ic_lock_lock"
                        app:startIconTint="#8C8C8C">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/inputConfirmPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/auth_confirm_password_hint"
                            android:imeOptions="actionNext"
                            android:inputType="textPassword"
                            android:minHeight="52dp"
                            android:nextFocusDown="@id/checkTerms"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:textColor="#2E2E2E"
                            android:textColorHint="#8A8A8A" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <androidx.appcompat.widget.AppCompatCheckBox
                        android:id="@+id/checkTerms"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/auth_terms_full"
                        app:buttonTint="@color/figma_primary" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/buttonCreateAccount"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_auth_button_ripple"
                        android:backgroundTint="@null"
                        android:padding="0dp"
                        android:stateListAnimator="@null"
                        android:text="@string/auth_create_account"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        app:backgroundTint="@null" />

                    <TextView
                        android:id="@+id/textLogin"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center"
                        android:text="@string/auth_login_link"
                        android:textColor="@color/figma_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
