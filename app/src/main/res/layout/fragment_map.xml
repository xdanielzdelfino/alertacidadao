<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@drawable/bg_header_gradient"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginEnd="12dp">
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    app:cardCornerRadius="17dp"
                    app:cardBackgroundColor="@color/avatar_bg_light"
                    app:strokeColor="@color/avatar_border_light"
                    app:strokeWidth="0.8dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="AC"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="12sp" />
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Alerta Cidadão"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mapa de Relatos"
                    android:textColor="@android:color/white"
                    android:textSize="10.88sp" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_margin="12dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/surface"
            app:elevation="4dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <org.osmdroid.views.MapView
                    android:id="@+id/mapView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/map_surface" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="342dp"
                    android:layout_height="39dp"
                    android:layout_gravity="top|start"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="7dp"
                    app:cardCornerRadius="14dp"
                    app:cardBackgroundColor="@color/surface"
                    app:elevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="10dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Legenda"
                            android:textSize="12.48sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_legend"
                            android:layout_marginEnd="16dp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginEnd="16dp">
                            <View
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:layout_marginEnd="3.2dp"
                                android:background="@drawable/dot_open" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Aberto"
                                android:textSize="11.52sp"
                                android:textColor="@color/text_legend" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginEnd="16dp">
                            <View
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:layout_marginEnd="3.2dp"
                                android:background="@drawable/dot_analysis" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Em Análise"
                                android:textSize="11.52sp"
                                android:textColor="@color/text_legend" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <View
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:layout_marginEnd="3.2dp"
                                android:background="@drawable/dot_resolved" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Resolvido"
                                android:textSize="11.52sp"
                                android:textColor="@color/text_legend" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <FrameLayout
                    android:layout_width="30dp"
                    android:layout_height="95dp"
                    android:layout_gravity="start|top"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="60dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="30dp"
                        android:layout_height="61dp"
                        app:cardCornerRadius="10dp"
                        app:cardBackgroundColor="@color/surface"
                        app:strokeColor="@color/divider"
                        app:strokeWidth="0.8dp"
                        app:elevation="1dp">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_gravity="top"
                                android:layout_marginTop="30dp"
                                android:background="@color/divider" />

                            <ImageView
                                android:id="@+id/btnZoomIn"
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:layout_gravity="top"
                                android:padding="6dp"
                                android:src="@drawable/ic_zoom_in"
                                android:contentDescription="@string/app_name" />

                            <ImageView
                                android:id="@+id/btnZoomOut"
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:layout_gravity="bottom"
                                android:padding="6dp"
                                android:src="@drawable/ic_zoom_out"
                                android:contentDescription="@string/app_name" />

                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnLocation"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_gravity="bottom|start"
                        android:layout_marginTop="4dp"
                        app:cardCornerRadius="10dp"
                        app:cardBackgroundColor="@color/surface"
                        app:strokeColor="@color/divider"
                        app:strokeWidth="0.8dp"
                        app:elevation="1dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="6dp"
                            android:src="@drawable/ic_location_compass"
                            android:contentDescription="@string/app_name" />
                    </com.google.android.material.card.MaterialCardView>
                </FrameLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnLayers"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="60dp"
                    android:layout_marginEnd="12dp"
                    app:cardCornerRadius="10dp"
                    app:cardBackgroundColor="@color/surface"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="0.8dp"
                    app:elevation="1dp">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="7dp"
                        android:src="@drawable/ic_layers"
                        android:contentDescription="@string/app_name" />
                </com.google.android.material.card.MaterialCardView>

            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

</FrameLayout>
